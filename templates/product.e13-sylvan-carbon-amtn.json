          "settings": {
            "title": "",
            "text": "<p><strong>Sidekick: </strong>Anti-kickback hub technology with adjustable deadband eliminates kickback and filters drivetrain vibration, improving ride feel and suspension performance</p><p><br/></p><p><strong>Free Speed: </strong>Exceptionally low drag and whisper-quiet operation of Sidekick gives free speed, carrying more momentum than other freehub systems</p><p></p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_hiYcTA": {
          "type": "column",
          "settings": {
            "title": "",
            "text": "<p><strong>Race Level Builds:</strong> handbuilt to exacting precision with Sapim D-light spokes and locking alloy nipples for ultimate performance and longevity</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_rhVPpJ": {
          "type": "column",
          "settings": {
            "title": "",
            "text": "<p><strong>Compliance:</strong> Rim designs combined with Race Level double-butted 28 spoke build gives a lively ride feel, making for a responsive and dynamic ride</p><p><strong><br/>Reliability: </strong>Tested on the World Cup and fully serviceable and rebuildable means ultimate reliability, so you can push your limits and ride with confidence. Lifetime carbon rim replacement warranty</p>",
            "link_label": "",
            "link": ""
          }
        }
