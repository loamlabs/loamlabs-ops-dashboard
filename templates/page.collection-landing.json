a>\n    </div>\n    <!-- HED Rims -->\n    <div class=\"flex-item\">\n      <a href=\"/collections/hed-rims\" class=\"grid-item-link\">\n        <div class=\"grid-item-logo-wrapper\">\n          {% if hed_logo != blank %}\n            <img src=\"{{ hed_logo }}\" alt=\"HED Rims Logo\" class=\"grid-item-logo\">\n          {% else %}\n            <h3>HED Rims</h3>\n          {% endif %}\n        </div>\n        <p>Pioneers in aerodynamics and wide-rim technology.</p>\n      </a>\n    </div>\n    <!-- Logos Rims -->\n    <div class=\"flex-item\">\n      <a href=\"/collections/logos-rims\" class=\"grid-item-link\">\n        <div class=\"grid-item-logo-wrapper\">\n          {% if logos_logo != blank %}\n            <img src=\"{{ logos_logo }}\" alt=\"Logos Rims Logo\" class=\"grid-item-logo\">\n          {% else %}\n            <h3>Logos Rims</h3>\n          {% endif %}\n        </div>\n        <p>A fantastic balance of quality and value.</p>\n      </a>\n    </div>\n    <!-- NOBL Carbon Rims -->\n    <div class=\"flex-item\">\n      <a href=\"/collections/nobl-rims\" class=\"grid-item-link\">\n        <div class=\"grid-item-logo-wrapper\">\n          {% if nobl_logo != blank %}\n            <img src=\"{{ nobl_logo }}\" alt=\"NOBL Carbon Rims Logo\" class=\"grid-item-logo\">\n          {% else %}\n            <h3>NOBL Carbon Rims</h3>\n          {% endif %}\n        </div>\n        <p>Premium carbon rims for MTB & Gravel.</p>\n      </a>\n    </div>\n    <!-- Race Face Rims -->\n    <div class=\"flex-item\">\n      <a href=\"/collections/race-face-rims\" class=\"grid-item-link\">\n        <div class=\"grid-item-logo-wrapper\">\n          {% if raceface_logo != blank %}\n            <img src=\"{{ raceface_logo }}\" alt=\"Race Face Rims Logo\" class=\"grid-item-logo\">\n          {% else %}\n            <h3>Race Face Rims</h3>\n          {% endif %}\n        </div>\n        <p>Bombproof rims built for the toughest conditions.</p>\n      </a>\n    </div>\n    <!-- Reserve Wheels Rims -->\n    <div class=\"flex-item\">\n      <a href=\"/collections/reserve-rims\" class=\"grid-item-link\">\n        <div class=\"grid-item-logo-wrapper\">\n          {% if reserve_logo != blank %}\n            <img src=\"{{ reserve_logo }}\" alt=\"Reserve Wheels Rims Logo\" class=\"grid-item-logo\">\n          {% else %}\n            <h3>Reserve Wheels Rims</h3>\n          {% endif %}\n        </div>\n        <p>High-performance carbon rims with a lifetime warranty.</p>\n      </a>\n    </div>\n    <!-- Spank Rims -->\n    <div class=\"flex-item\">\n      <a href=\"/collections/spank-rims\" class=\"grid-item-link\">\n        <div class=\"grid-item-logo-wrapper\">\n          {% if spank_logo != blank %}\n            <img src=\"{{ spank_logo }}\" alt=\"Spank Rims Logo\" class=\"grid-item-logo\">\n          {% else %}\n            <h3>Spank Rims</h3>\n          {% endif %}\n        </div>\n        <p>Innovative Vibrocore technology for a smoother ride.</p>\n      </a>\n    </div>\n    <!-- Stan's NoTubes Rims -->\n    <div class=\"flex-item\">\n      <a href=\"/collections/stans-rims\" class=\"grid-item-link\">\n        <div class=\"grid-item-logo-wrapper\">\n          {% if stans_logo != blank %}\n            <img src=\"{{ stans_logo }}\" alt=\"Stan's NoTubes Rims Logo\" class=\"grid-item-logo\">\n          {% else %}\n            <h3>Stan's NoTubes Rims</h3>\n          {% endif %}\n        </div>\n        <p>The original and trusted name in tubeless technology.</p>\n      </a>\n    </div>\n    <!-- We Are One Rims -->\n    <div class=\"flex-item\">\n      <a href=\"/collections/we-are-one-rims\" class=\"grid-item-link\">\n        <div class=\"grid-item-logo-wrapper\">\n          {% if wao_logo != blank %}\n            <img src=\"{{ wao_logo }}\" alt=\"We Are One Rims Logo\" class=\"grid-item-logo\">\n          {% else %}\n            <h3>We Are One Rims</h3>\n          {% endif %}\n        </div>\n        <p>Handcrafted in Canada, backed by a lifetime warranty.</p>\n      </a>\n    </div>\n\n  </div>\n</div>\n\n<!-- SHOP BY MATERIAL SECTION -->\n<div class=\"landing-page-section\">\n  <h2>Shop by Material</h2>\n  <div class=\"flex-container\">\n    <div class=\"flex-item\">\n      <a href=\"/collections/all-rims\">\n        <div class=\"flex-item-content-wrapper\">\n          <h3>View All Rims</h3>\n        </div>\n        <p>Browse our entire catalog and use our filters to find the perfect rim.</p>\n      </a>\n    </div>\n    <div class=\"flex-item\">\n      <a href=\"/collections/carbon-rims\">\n        <div class=\"flex-item-content-wrapper\">\n          <h3>Carbon Rims</h3>\n        </div>\n        <p>For the ultimate in lightweight performance and stiffness.</p>\n      </a>\n    </div>\n    <div class=\"flex-item\">\n      <a href=\"/collections/alloy-rim\">\n        <div class=\"flex-item-content-wrapper\">\n          <h3>Alloy Rims</h3>\n        </div>\n        <p>For proven durability and exceptional value.</p>\n      </a>\n    </div>\n  </div>\n</div>\n\n<!-- SHOP BY SIZE SECTION -->\n<div class=\"landing-page-section\">\n  <h2>Shop by Size</h2>\n  <div class=\"flex-container\">\n    <!-- 29 Inch -->\n    <div class=\"flex-item\">\n      <a href=\"/collections/29-inch-rims\">\n        <div class=\"flex-item-content-wrapper\">\n          {% if size_29_logo != blank %}<img src=\"{{ size_29_logo }}\" alt=\"29 Inch Rims\" class=\"flex-item-logo\">{% else %}<h3>29 Inch Rims</h3>{% endif %}\n        </div>\n        <p>For modern MTB & Gravel bikes.</p>\n      </a>\n    </div>\n    <!-- 27.5 Inch -->\n    <div class=\"flex-item\">\n      <a href=\"/collections/27-5-inch-rims\">\n        <div class=\"flex-item-content-wrapper\">\n          {% if size_275_logo != blank %}<img src=\"{{ size_275_logo }}\" alt=\"27.5 Inch Rims\" class=\"flex-item-logo\">{% else %}<h3>27.5\" Rims</h3>{% endif %}\n        </div>\n        <p>For playful trail & enduro bikes.</p>\n      </a>\n    </div>\n    <!-- 26 Inch -->\n    <div class=\"flex-item\">\n      <a href=\"/collections/26-inch-rims\">\n        <div class=\"flex-item-content-wrapper\">\n          {% if size_26_logo != blank %}<img src=\"{{ size_26_logo }}\" alt=\"26 Inch Rims\" class=\"flex-item-logo\">{% else %}<h3>26 Inch Rims</h3>{% endif %}\n        </div>\n        <p>For Dirt Jump & classic MTB.</p>\n      </a>\n    </div>\n    <!-- 700c -->\n    <div class=\"flex-item\">\n      <a href=\"/collections/700c-rims\">\n        <div class=\"flex-item-content-wrapper\">\n          {% if size_700c_logo != blank %}<img src=\"{{ size_700c_logo }}\" alt=\"700c Rims\" class=\"flex-item-logo\">{% else %}<h3>700c Rims</h3>{% endif %}\n        </div>\n        <p>The standard for Road & Gravel.</p>\n      </a>\n    </div>\n    <!-- 650b -->\n    <div class=\"flex-item\">\n      <a href=\"/collections/650b-rims\">\n        <div class=\"flex-item-content-wrapper\">\n          {% if size_650b_logo != blank %}<img src=\"{{ size_650b_logo }}\" alt=\"650b Rims\" class=\"flex-item-logo\">{% else %}<h3>650b Rims</h3>{% endif %}\n        </div>\n        <p>For \"Road Plus\" & All-Road adventure.</p>\n      </a>\n    </div>\n  </div>\n</div>",
