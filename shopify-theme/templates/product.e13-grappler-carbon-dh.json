    "multicolumn_degCQ4": {
      "type": "multicolumn",
      "blocks": {
        "column_NKaBFU": {
          "type": "column",
          "settings": {
            "title": "",
            "text": "<p><strong>Lively Ride Feel:</strong> Low profile height combined with double-butted 28-spoke build adds wheel strength while maintaining a responsive and dynamic ride</p><p><strong><br/>Free Speed:</strong> Sidekick has exceptionally low drag, carrying more speed than other freehub systems</p><p></p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_hiYcTA": {
          "type": "column",
          "settings": {
            "title": "",
            "text": "<p><strong>Improved suspension performance:</strong> Sidekick hubs decouple the drivetrain from the suspension. This eliminates kickback at its source, filters drivetrain vibration, improving ride feel and suspension performance</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_rhVPpJ": {
          "type": "column",
          "settings": {
            "title": "",
            "text": "<p><strong>Enhanced comfort and control:</strong> Ultra-compliant, low-profile Flux Carbon rims add radial compliance and traction without reducing steering precision and feel<br/><br/></p><p><strong>Ultimate reliability:</strong> Proven on the World Cup and fully serviceable and rebuildable, so you can push your limits and ride with confidence. Lifetime Rim Warranty</p>",
            "link_label": "",
            "link": ""
          }
        }
      },
