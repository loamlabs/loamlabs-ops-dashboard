<script>
  // This object is for analytics and detailed data
  window._loamlabs_customer_data = {};
  {% if customer %}
    window._loamlabs_customer_data = {
      isLoggedIn: true,
      id: {{ customer.id | json }},
      email: {{ customer.email | json }},
      first_name: {{ customer.first_name | json }},
      last_name: {{ customer.last_name | json }},
      tags: {{ customer.tags | json }} // <-- This is the new line
    };
  {% else %}
    window._loamlabs_customer_data = { isLoggedIn: false };
  {% endif %}

  // This simple object is used by the builder for the discount logic
  window.loamlabs = window.loamlabs || {};
  window.loamlabs.customer = {
    isLoggedIn: {% if customer %}true{% else %}false{% endif %}
  };
</script>

