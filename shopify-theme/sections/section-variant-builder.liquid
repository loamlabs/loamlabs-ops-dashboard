{% comment %} --- JavaScript Configuration & Initialization --- {% endcomment %}
<script>
  /* Ensure Storefront Token is passed */
  window.loamlabs = window.loamlabs || {};
  function showBuilderConfigError(message) { console.error("Builder Config Error:", message); const step0 = document.getElementById('step-0'); const step0Msg = step0 ? step0.querySelector('.error-message') : null; const step1 = document.getElementById('step-1'); const step2 = document.getElementById('step-2'); const step3 = document.getElementById('step-3'); const summary = document.getElementById('build-summary'); if (step0 && step0Msg) { step0Msg.textContent = message; step0.style.display = 'flex'; step0.style.flexDirection = 'column'; step0.style.alignItems = 'center'; } else { (document.getElementById('variant-builder-container') || document.body).innerHTML = `<div style="color: red; border: 1px solid red; padding: 15px; text-align: center;">${message}</div>`; } if (step1) step1.style.display = 'none'; if (step2) step2.style.display = 'none'; if (step3) step3.style.display = 'none'; if (summary) summary.style.display = 'none'; }
  const builderContainerElement = document.getElementById('variant-builder-container');
  let storefrontToken = '';
  if (!builderContainerElement) {
    console.error("CRITICAL: Builder container 'variant-builder-container' not found in DOM.");
  } else {
    storefrontToken = builderContainerElement.dataset.storefrontApiToken;
    if (!storefrontToken || storefrontToken.trim() === '') {
      storefrontToken = ''; // Ensure it's empty if invalid
      showBuilderConfigError('Configuration Error: Storefront API access token is missing or invalid. Please check Theme settings.');
    }
  }
  if (storefrontToken) {
    window.loamlabs.builderConfig = { storefrontApiToken: storefrontToken };
    console.log("Builder Config Initialized with Token.");
  } else {
    window.loamlabs.builderConfig = { storefrontApiToken: null }; // Ensure config object exists even if token is missing
  }
</script>

