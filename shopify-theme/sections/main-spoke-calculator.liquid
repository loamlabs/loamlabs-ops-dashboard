<!-- MODAL FOR DISCLAIMER CONFIRMATION -->
<div class="ll-modal-overlay is-hidden" id="ll-disclaimer-modal">
  <div class="ll-modal-content">
    <h3 class="ll-modal-title">Please Verify Your Inputs</h3>
    <div class="ll-modal-body">
      <p>This tool provides a precise spoke length based on the numbers you enter. The accuracy of the result depends entirely on the accuracy of your inputs.</p>
      <p><strong>Please confirm the following:</strong></p>
      <ul>
        <li><strong>Your ERD is correct.</strong> Effective Rim Diameter is the most critical measurement. Always measure it yourself if possible.</li>
        <li><strong>Nipple washers are accounted for.</strong> If your ERD measurement *already includes* washer thickness, please leave the 'Nipple Washer Thickness' field at 0 to avoid double-counting.</li>
        <li><strong>Your Hub is correct.</strong> Confirm you have selected the exact hub model you intend to use and have verified its dimensions against official manufacturer specifications.</li>
      </ul>
      <p><small>By accepting, you acknowledge that you have verified your inputs and that LoamLabs is not liable for costs incurred from incorrect spoke lengths.</small></p>
      <div class="ll-disclaimer-acceptance">
        <input type="checkbox" id="ll-disclaimer-checkbox">
        <label for="ll-disclaimer-checkbox">I have read, understood, and verified my inputs.</label>
      </div>
      <div class="ll-disclaimer-actions">
        <button id="ll-disclaimer-cancel" class="ll-button-secondary">Cancel</button>
        <button id="ll-disclaimer-accept" class="ll-button-primary" disabled>Accept & Calculate</button>
      </div>
    </div>
  </div>
</div>

<!-- MODAL FOR ACCURACY & TERMS -->
